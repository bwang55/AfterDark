NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token
# Optional: point frontend to deployed AWS endpoint, e.g. https://xxxx.execute-api.us-east-1.amazonaws.com/prod/places
NEXT_PUBLIC_PLACES_API_URL=
# Optional: enables venue photos in place popups (Google Places API)
GOOGLE_PLACES_API_KEY=
# Required for AI chat feature
OPENAI_API_KEY=
# Optional: point AI chat to a custom endpoint (e.g., API Gateway)
# NEXT_PUBLIC_AI_CHAT_URL=
# Optional: point chat-history fetch to deployed API Gateway endpoint
# NEXT_PUBLIC_CHAT_HISTORY_URL=
# Optional: override default model (default: gpt-4o)
# AI_CHAT_MODEL=
# Optional: override OpenAI API endpoint (e.g., for proxy/gateway)
# AI_CHAT_ENDPOINT_URL=
# Optional: Upstash Redis for distributed rate limiting (recommended for production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional: CORS allowed origins (comma-separated, used by Lambda handlers)
# ALLOW_ORIGIN=https://yourdomain.com
